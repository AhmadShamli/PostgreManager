{% extends 'layouts/app.html.twig' %}
{% block title %}Schemas — {{ db }} — PostgreManager{% endblock %}
{% block page_title %}Schemas in {{ db }}{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item"><a href="/databases?server_id={{ server_id }}">Databases</a></li><li class="breadcrumb-item active">{{ db }}</li>{% endblock %}

{% block content %}
<div class="card" style="background:#1a1a2e; border:1px solid #0f3460;">
    <div class="card-header" style="background:#16213e; border-bottom:1px solid #0f3460;">
        <h3 class="card-title" style="color:#e94560;"><i class="fas fa-layer-group mr-2"></i>Schemas</h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0" style="color:#ddd;">
            <thead style="background:#0f3460;"><tr><th>Schema</th><th>Actions</th></tr></thead>
            <tbody>
            {% for s in schemas %}
            <tr>
                <td><i class="fas fa-layer-group mr-1" style="color:#17a2b8;"></i>{{ s.name }}</td>
                <td>
                    <a href="/databases/{{ db }}/schemas/{{ s.name }}/tables?server_id={{ server_id }}" class="btn btn-xs btn-outline-info">
                        <i class="fas fa-table mr-1"></i>Browse Tables
                    </a>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="2" class="text-center p-4" style="color:#555;">No schemas found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
