{% extends 'layouts/app.html.twig' %}
{% block title %}{{ table }} Data — PostgreManager{% endblock %}
{% block page_title %}Data: {{ schema }}.{{ table }}{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="/databases?server_id={{ server_id }}">Databases</a></li>
<li class="breadcrumb-item"><a href="/databases/{{ db }}/schemas/{{ schema }}/tables?server_id={{ server_id }}">{{ db }}/{{ schema }}</a></li>
<li class="breadcrumb-item active">{{ table }}</li>
{% endblock %}

{% block content %}
<div class="card" style="background:#1a1a2e; border:1px solid #0f3460;">
    <div class="card-header d-flex justify-content-between align-items-center" style="background:#16213e; border-bottom:1px solid #0f3460;">
        <h3 class="card-title mb-0" style="color:#e94560;"><i class="fas fa-search mr-2"></i>{{ data.total|number_format }} rows — Page {{ data.page }}</h3>
        <div>
            <a href="/databases/{{ db }}/schemas/{{ schema }}/tables/{{ table }}/export?server_id={{ server_id }}&format=csv" class="btn btn-xs btn-outline-success mr-1"><i class="fas fa-file-csv mr-1"></i>CSV</a>
            <a href="/databases/{{ db }}/schemas/{{ schema }}/tables/{{ table }}/export?server_id={{ server_id }}&format=json" class="btn btn-xs btn-outline-info"><i class="fas fa-file-code mr-1"></i>JSON</a>
        </div>
    </div>
    <div class="card-body p-0">
        {% if data.rows %}
        <div class="table-responsive" style="max-height:500px; overflow:auto;">
        <table class="table table-sm table-hover mb-0" style="color:#ddd; font-size:0.82rem;">
            <thead style="background:#0f3460; position:sticky; top:0;">
                <tr>
                    {% for col in data.rows[0]|keys %}
                    <th style="white-space:nowrap;">{{ col }}</th>
                    {% endfor %}
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for row in data.rows %}
            <tr>
                {% for val in row %}
                <td style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="{{ val }}">
                    {{ val is null ? '<em style="color:#555;">NULL</em>'|raw : val }}
                </td>
                {% endfor %}
                <td>
                    <button class="btn btn-xs btn-outline-danger"
                        onclick="if(confirm('Delete this row?'))document.getElementById('del-{{ loop.index }}').submit()">
                        <i class="fas fa-trash"></i>
                    </button>
                    <form id="del-{{ loop.index }}" method="POST"
                        action="/databases/{{ db }}/schemas/{{ schema }}/tables/{{ table }}/data/{{ row.ctid ?? loop.index }}/delete"
                        style="display:none;">
                        <input type="hidden" name="server_id" value="{{ server_id }}">
                    </form>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        </div>

        <!-- Pagination -->
        <div class="p-3 d-flex justify-content-between align-items-center" style="border-top:1px solid #0f3460;">
            <span style="color:#aaa;">{{ data.total|number_format }} total rows</span>
            <div>
                {% if data.page > 1 %}
                <a href="?server_id={{ server_id }}&page={{ data.page - 1 }}" class="btn btn-sm btn-outline-secondary mr-1">
                    <i class="fas fa-chevron-left"></i> Prev
                </a>
                {% endif %}
                {% if data.page * data.per_page < data.total %}
                <a href="?server_id={{ server_id }}&page={{ data.page + 1 }}" class="btn btn-sm btn-outline-secondary">
                    Next <i class="fas fa-chevron-right"></i>
                </a>
                {% endif %}
            </div>
        </div>

        {% else %}
        <div class="text-center p-5" style="color:#555;">This table is empty.</div>
        {% endif %}
    </div>
</div>
{% endblock %}
