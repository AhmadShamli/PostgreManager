{% extends 'layouts/app.html.twig' %}
{% block title %}Create Database — PostgreManager{% endblock %}
{% block page_title %}Create Database{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item"><a href="/databases?server_id={{ server_id }}">Databases</a></li><li class="breadcrumb-item active">Create</li>{% endblock %}

{% block content %}
<div class="card" style="background:#1a1a2e; border:1px solid #0f3460; max-width:520px;">
    <div class="card-header" style="background:#16213e; border-bottom:1px solid #0f3460;">
        <h3 class="card-title" style="color:#e94560;"><i class="fas fa-database mr-2"></i>New Database</h3>
    </div>
    <div class="card-body">
        <form method="POST" action="/databases">
            <input type="hidden" name="server_id" value="{{ server_id }}">
            <div class="form-group">
                <label style="color:#ddd;">Database Name <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control pm-input" required placeholder="my_database" pattern="[a-zA-Z_][a-zA-Z0-9_]*">
                <small style="color:#aaa;">Alphanumeric and underscores only.</small>
            </div>
            <div class="form-group">
                <label style="color:#ddd;">Owner <small style="color:#aaa;">(optional)</small></label>
                <input type="text" name="owner" class="form-control pm-input" placeholder="postgres">
            </div>
            <div class="form-group">
                <label style="color:#ddd;">Connection Limit <small style="color:#aaa;">(-1 = unlimited)</small></label>
                <input type="number" name="conn_limit" class="form-control pm-input" value="-1" min="-1">
            </div>
            <button type="submit" class="btn btn-primary mr-2" style="background:#e94560; border-color:#e94560;">
                <i class="fas fa-plus mr-1"></i>Create
            </button>
            <a href="/databases?server_id={{ server_id }}" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
{% endblock %}
