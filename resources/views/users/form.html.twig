{% extends 'layouts/app.html.twig' %}
{% block title %}{% if user %}Edit User{% else %}New User{% endif %} — PostgreManager{% endblock %}
{% block page_title %}{% if user %}Edit User{% else %}New User{% endif %}{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item"><a href="/app-users">App Users</a></li><li class="breadcrumb-item active">{% if user %}Edit{% else %}New{% endif %}</li>{% endblock %}

{% block content %}
<div class="card" style="background:#1a1a2e; border:1px solid #0f3460; max-width:520px;">
    <div class="card-header" style="background:#16213e; border-bottom:1px solid #0f3460;">
        <h3 class="card-title" style="color:#e94560;"><i class="fas fa-user mr-2"></i>User Details</h3>
    </div>
    <div class="card-body">
        {% if errors is defined %}
        <div class="alert alert-danger"><ul class="mb-0">{% for e in errors %}<li>{{ e }}</li>{% endfor %}</ul></div>
        {% endif %}

        <form method="POST" action="{{ user ? '/app-users/' ~ user.id : '/app-users' }}">
            <div class="form-group">
                <label style="color:#ddd;">Full Name</label>
                <input type="text" name="name" class="form-control pm-input" value="{{ user.name ?? old.name ?? '' }}" required>
            </div>
            <div class="form-group">
                <label style="color:#ddd;">Email</label>
                <input type="email" name="email" class="form-control pm-input" value="{{ user.email ?? old.email ?? '' }}" required>
            </div>
            <div class="form-group">
                <label style="color:#ddd;">Password {% if user %}<small style="color:#aaa;">(leave blank to keep)</small>{% endif %}</label>
                <input type="password" name="password" class="form-control pm-input" {% if not user %}required{% endif %}>
            </div>
            <div class="form-group">
                <label style="color:#ddd;">Role</label>
                <select name="role" class="form-control pm-input">
                    {% for r in ['viewer', 'admin', 'super_admin'] %}
                    <option value="{{ r }}" {% if (user.role ?? old.role ?? 'viewer') == r %}selected{% endif %}>{{ r }}</option>
                    {% endfor %}
                </select>
            </div>
            {% if user %}
            <div class="custom-control custom-switch mb-3">
                <input type="checkbox" class="custom-control-input" id="is_active" name="is_active"
                       {% if user.is_active %}checked{% endif %}>
                <label class="custom-control-label" for="is_active" style="color:#ddd;">Active</label>
            </div>
            {% endif %}
            <button type="submit" class="btn btn-primary mr-2" style="background:#e94560; border-color:#e94560;">
                <i class="fas fa-save mr-1"></i>Save
            </button>
            <a href="/app-users" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
{% endblock %}
