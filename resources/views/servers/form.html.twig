{% extends 'layouts/app.html.twig' %}
{% block title %}{% if profile %}Edit Server{% else %}Add Server{% endif %} — PostgreManager{% endblock %}
{% block page_title %}{% if profile %}Edit Server{% else %}Add Server{% endif %}{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="/servers">Servers</a></li>
<li class="breadcrumb-item active">{% if profile %}Edit{% else %}Add{% endif %}</li>
{% endblock %}

{% block content %}
<div class="card" style="background:#1a1a2e; border:1px solid #0f3460; max-width:680px;">
    <div class="card-header" style="background:#16213e; border-bottom:1px solid #0f3460;">
        <h3 class="card-title" style="color:#e94560;"><i class="fas fa-server mr-2"></i>Server Details</h3>
    </div>
    <div class="card-body">
        <form method="POST" action="{{ profile ? '/servers/' ~ profile.id : '/servers' }}" id="server-form">

            <div class="form-group">
                <label style="color:#ddd;">Label <span class="text-danger">*</span></label>
                <input type="text" name="label" class="form-control pm-input" placeholder="My Production DB"
                       value="{{ profile.label ?? '' }}" required>
            </div>

            <div class="row">
                <div class="col-md-8">
                    <div class="form-group">
                        <label style="color:#ddd;">Host <span class="text-danger">*</span></label>
                        <input type="text" name="host" class="form-control pm-input" placeholder="127.0.0.1"
                               value="{{ profile.host ?? '127.0.0.1' }}" required>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label style="color:#ddd;">Port</label>
                        <input type="number" name="port" class="form-control pm-input" value="{{ profile.port ?? 5432 }}">
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label style="color:#ddd;">Default Database</label>
                <input type="text" name="db_name" class="form-control pm-input" placeholder="postgres"
                       value="{{ profile.db_name ?? 'postgres' }}">
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label style="color:#ddd;">PG Username <span class="text-danger">*</span></label>
                        <input type="text" name="pg_username" class="form-control pm-input"
                               value="{{ profile.pg_username ?? '' }}" required>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label style="color:#ddd;">PG Password {% if profile %}<small style="color:#aaa;">(leave blank to keep)</small>{% endif %}</label>
                        <input type="password" name="pg_password" class="form-control pm-input"
                               {% if not profile %}required{% endif %}>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <div class="custom-control custom-switch">
                    <input type="checkbox" class="custom-control-input" id="is_shared" name="is_shared"
                           {% if profile.is_shared ?? false %}checked{% endif %}>
                    <label class="custom-control-label" for="is_shared" style="color:#ddd;">Shared (visible to all app users)</label>
                </div>
            </div>

            <div class="d-flex align-items-center">
                <button type="submit" class="btn btn-primary mr-2" style="background:#e94560; border-color:#e94560;">
                    <i class="fas fa-save mr-1"></i>Save
                </button>
                <button type="button" class="btn btn-outline-info mr-2" id="test-btn">
                    <i class="fas fa-plug mr-1"></i>Test Connection
                </button>
                <a href="/servers" class="btn btn-outline-secondary">Cancel</a>
                <span id="test-result" class="ml-3"></span>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.getElementById('test-btn').addEventListener('click', function() {
    const form = document.getElementById('server-form');
    const data = new FormData(form);
    const btn  = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Testing...';
    fetch('/servers/test', { method: 'POST', body: data })
        .then(r => r.json())
        .then(d => {
            document.getElementById('test-result').innerHTML = d.success
                ? '<span class="text-success"><i class="fas fa-check-circle mr-1"></i>' + d.message + '</span>'
                : '<span class="text-danger"><i class="fas fa-times-circle mr-1"></i>' + d.message + '</span>';
        })
        .finally(() => { btn.disabled = false; btn.innerHTML = '<i class="fas fa-plug mr-1"></i>Test Connection'; });
});
</script>
{% endblock %}
