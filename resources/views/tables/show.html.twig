{% extends 'layouts/app.html.twig' %}
{% block title %}{{ table }} — Structure — PostgreManager{% endblock %}
{% block page_title %}{{ schema }}.{{ table }} — Structure{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="/databases?server_id={{ server_id }}">Databases</a></li>
<li class="breadcrumb-item"><a href="/databases/{{ db }}/schemas/{{ schema }}/tables?server_id={{ server_id }}">{{ db }}/{{ schema }}</a></li>
<li class="breadcrumb-item active">{{ table }}</li>
{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-8">
        <div class="card" style="background:#1a1a2e; border:1px solid #0f3460;">
            <div class="card-header" style="background:#16213e; border-bottom:1px solid #0f3460;">
                <h3 class="card-title" style="color:#e94560;"><i class="fas fa-columns mr-2"></i>Columns</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0" style="color:#ddd;">
                    <thead style="background:#0f3460;"><tr><th>Column</th><th>Type</th><th>Nullable</th><th>Default</th></tr></thead>
                    <tbody>
                    {% for c in columns %}
                    <tr>
                        <td><code style="color:#17a2b8;">{{ c.name }}</code></td>
                        <td><span class="badge badge-secondary">{{ c.data_type }}{% if c.character_maximum_length %}({{ c.character_maximum_length }}){% endif %}</span></td>
                        <td>{{ c.is_nullable == 'YES' ? 'YES' : '<strong style="color:#e94560;">NO</strong>'|raw }}</td>
                        <td><code style="color:#aaa; font-size:0.75rem;">{{ c.column_default ?? '—' }}</code></td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="background:#1a1a2e; border:1px solid #0f3460;">
            <div class="card-header" style="background:#16213e; border-bottom:1px solid #0f3460;">
                <h3 class="card-title" style="color:#e94560;"><i class="fas fa-search mr-2"></i>Indexes</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0" style="color:#ddd;">
                    <thead style="background:#0f3460;"><tr><th>Index</th><th>Definition</th></tr></thead>
                    <tbody>
                    {% for idx in indexes %}
                    <tr>
                        <td>{{ idx.name }}</td>
                        <td><code style="font-size:0.7rem; color:#aaa;">{{ idx.definition|slice(0,60) }}</code></td>
                    </tr>
                    {% else %}
                    <tr><td colspan="2" class="text-center p-3" style="color:#555;">No indexes</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-2">
            <a href="/databases/{{ db }}/schemas/{{ schema }}/tables/{{ table }}/data?server_id={{ server_id }}" class="btn btn-outline-info btn-block">
                <i class="fas fa-search mr-1"></i>Browse Data
            </a>
        </div>
    </div>
</div>
{% endblock %}
