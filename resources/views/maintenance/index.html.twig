{% extends 'layouts/app.html.twig' %}
{% block title %}Maintenance — PostgreManager{% endblock %}
{% block page_title %}Maintenance{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Maintenance</li>{% endblock %}

{% block content %}
<div class="row">
    <!-- Vacuum -->
    <div class="col-md-6">
        <div class="card" style="background:#1a1a2e; border:1px solid #0f3460;">
            <div class="card-header" style="background:#16213e; border-bottom:1px solid #0f3460;">
                <h3 class="card-title" style="color:#e94560;"><i class="fas fa-broom mr-2"></i>VACUUM / ANALYZE</h3>
            </div>
            <div class="card-body">
                <form method="POST" action="/maintenance/vacuum">
                    <input type="hidden" name="server_id" value="{{ server_id }}">
                    <div class="form-group">
                        <label style="color:#ddd;">Database</label>
                        <select name="db" class="form-control pm-input">
                            {% for db in databases %}
                            <option value="{{ db.name }}">{{ db.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label style="color:#ddd;">Schema</label>
                        <input type="text" name="schema" class="form-control pm-input" value="public">
                    </div>
                    <div class="form-group">
                        <label style="color:#ddd;">Table</label>
                        <input type="text" name="table" class="form-control pm-input" placeholder="table_name" required>
                    </div>
                    <div class="custom-control custom-switch mb-3">
                        <input type="checkbox" class="custom-control-input" id="vacuum_full" name="full">
                        <label class="custom-control-label" for="vacuum_full" style="color:#ddd;">VACUUM FULL <small style="color:#aaa;">(locks table)</small></label>
                    </div>
                    <button type="submit" class="btn btn-warning btn-block" onclick="return confirm('Run VACUUM?')">
                        <i class="fas fa-broom mr-1"></i>Run VACUUM ANALYZE
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Backup -->
    <div class="col-md-6">
        <div class="card" style="background:#1a1a2e; border:1px solid #0f3460;">
            <div class="card-header" style="background:#16213e; border-bottom:1px solid #0f3460;">
                <h3 class="card-title" style="color:#e94560;"><i class="fas fa-download mr-2"></i>Backup</h3>
            </div>
            <div class="card-body">
                <form method="POST" action="/maintenance/backup">
                    <input type="hidden" name="server_id" value="{{ server_id }}">
                    <div class="form-group">
                        <label style="color:#ddd;">Database to Backup</label>
                        <select name="db" class="form-control pm-input">
                            {% for db in databases %}
                            <option value="{{ db.name }}">{{ db.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button type="submit" class="btn btn-info btn-block">
                        <i class="fas fa-download mr-1"></i>Download SQL Dump
                    </button>
                </form>
                <hr style="border-color:#0f3460;">
                <a href="/maintenance/logs?server_id={{ server_id }}" class="btn btn-outline-secondary btn-block">
                    <i class="fas fa-list-alt mr-1"></i>View Activity Log
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
