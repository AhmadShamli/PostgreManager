{% extends 'layouts/app.html.twig' %}
{% block title %}Settings — PostgreManager{% endblock %}
{% block page_title %}Settings{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Settings</li>{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-6">
        <div class="card" style="background:#1a1a2e; border:1px solid #0f3460;">
            <div class="card-header" style="background:#16213e; border-bottom:1px solid #0f3460;">
                <h3 class="card-title" style="color:#e94560;"><i class="fas fa-sliders-h mr-2"></i>App Settings</h3>
            </div>
            <div class="card-body">
                <form method="POST" action="/settings">
                    <div class="form-group">
                        <label style="color:#ddd;">UI Theme</label>
                        <select name="ui_theme" class="form-control pm-input">
                            <option value="dark" {% if theme == 'dark' %}selected{% endif %}>Dark</option>
                            <option value="light" {% if theme == 'light' %}selected{% endif %}>Light</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label style="color:#ddd;">Query Timeout (seconds)</label>
                        <input type="number" name="query_timeout" class="form-control pm-input" value="{{ timeout }}" min="5" max="300">
                    </div>
                    <div class="form-group">
                        <label style="color:#ddd;">Default Row Limit</label>
                        <select name="row_limit" class="form-control pm-input">
                            {% for n in [25, 50, 100, 250, 500] %}
                            <option value="{{ n }}" {% if row_limit == n %}selected{% endif %}>{{ n }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary" style="background:#e94560; border-color:#e94560;">
                        <i class="fas fa-save mr-1"></i>Save Settings
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
